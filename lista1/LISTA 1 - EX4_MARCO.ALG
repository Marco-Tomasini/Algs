Algoritmo "Lista 1 - ex4_Marco"



Var
   vi,a,t,vo: real


Inicio
      escreval("Qual velocidade inicial do objeto?")
      leia(vi)
      escreval("Qual a aceleração?")
      leia(a)
      escreval("Qual o tempo levado para percorrer?")
      leia(t)
      
      vo <- vi + a * t
      
      escreval("A velocidade do objeto é de:", vo)



Fimalgoritmo