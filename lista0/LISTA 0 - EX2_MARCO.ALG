Algoritmo "Lista 1 - ex2_Marco"



Var
   n1,n2,n3,media: real


Inicio
      escreval("Digite a 1° nota")
      leia(n1)
      escreval("Digite o 2° nota")
      leia(n2)
      escreval("Digite o 3° nota")
      leia(n3)
      
      media<- ((n1*2)+(n2*3)+(n3*5))/10
      
      escreval("A média ponderada é: ", media)



Fimalgoritmo